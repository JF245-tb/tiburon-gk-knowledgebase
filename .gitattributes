# Git LFS — track PDFs via Large File Storage
# Required for files >50MB (SD.pdf = 72MB, CL.pdf = 46MB in Electrical Troubleshooting Manual)
# All PDFs tracked uniformly for consistency

*.pdf filter=lfs diff=lfs merge=lfs -text
*.PDF filter=lfs diff=lfs merge=lfs -text

# Oil analysis PDFs in builds/ also tracked via LFS
Knowledgebase/builds/**/*.pdf filter=lfs diff=lfs merge=lfs -text

# Ensure consistent line endings for text files
*.md text eol=lf
*.json text eol=lf
*.py text eol=lf
*.js text eol=lf
*.jsonl text eol=lf
